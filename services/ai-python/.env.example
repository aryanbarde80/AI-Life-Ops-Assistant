# AI Life Ops Assistant — Backend Environment Variables
# Copy this file to `.env` and fill in your values.
# Never commit the actual .env file to version control.

# ──────────────────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────────────────
# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────
# Firebase / Firestore
# ──────────────────────────────────────────────────────────────
# Base64-encoded Firebase service account JSON.
#
# How to generate:
#   1. Go to Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" — downloads a JSON file
#   3. Encode it:
#        Linux/macOS: base64 -w 0 service-account.json
#        Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#   4. Paste the result below (one long string, no newlines):
FIREBASE_CONFIG=<base64-encoded-service-account-json>
